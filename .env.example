# Character Engine — environment variables
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# For Netlify/Vercel deploys, set the same variables in the hosting dashboard's
# environment-variable panel AND redeploy — these are baked in at build time.

# --- Supabase ---
# From Supabase project → Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Claude / Anthropic API ---
# Get a key at https://console.anthropic.com/ — must start with "sk-ant-".
# Without this, manuscript analysis silently fails with a "Claude API key not
# configured" toast and ZERO tokens are spent. If your Anthropic billing shows
# no recent usage after an analysis run, suspect this variable.
VITE_CLAUDE_API_KEY=sk-ant-your-key-here
